<launch>
  <!-- Defaults align with turn_on_wheeltec_robot:
       - Laser topic: /scan
       - Laser frame: laser (must match TF base_footprint -> laser) -->
  <arg name="device_model" default="MS200"/>
  <arg name="frame_id" default="laser"/>
  <arg name="scan_topic" default="/scan"/>
  <arg name="port_name" default="/dev/ttyUSB0"/>
  <arg name="baudrate" default="230400"/>
  <arg name="angle_min" default="0.00"/>
  <arg name="angle_max" default="360.00"/>
  <arg name="range_min" default="0.05"/>
  <arg name="range_max" default="20.0"/>
  <arg name="clockwise" default="false"/>
  <arg name="motor_speed" default="10"/>

  <node pkg="oradar_lidar" type="oradar_scan" name="oradar_scan" output="screen">

    <param name="device_model" type="string"   value="$(arg device_model)"/> <!--设备型号: MS200-->
    <param name="frame_id"     type="string"   value="$(arg frame_id)"/> <!--配置frame_id-->
    <param name="scan_topic"   type="string"   value="$(arg scan_topic)"/> <!--设置激光雷达的topic名称-->
    <param name="port_name"    type="string"   value="$(arg port_name)"/> <!--配置串口设备port: dev/ttyUSB0-->
    <param name="baudrate"     type="int"      value="$(arg baudrate)"/> <!--配置串口波特率:230400-->
    <param name="angle_min"    type="double"   value="$(arg angle_min)" /> <!--设置最小角度，单位度.取值范围[0,360].default=0.0-->
    <param name="angle_max"    type="double"   value="$(arg angle_max)"/> <!--设置最大角度，单位度.取值范围[0,360].default=360.0-->
    <param name="range_min"    type="double"   value="$(arg range_min)" /> <!--设置最小距离，单位米，default=0.05-->
    <param name="range_max"    type="double"   value="$(arg range_max)" /> <!--设置最大距离，单位米，default=20.0-->
    <param name="clockwise"    type="bool"     value="$(arg clockwise)"/> <!--配置点云方向，true为顺时针， false为逆时针-->
    <param name="motor_speed"  type="int"      value="$(arg motor_speed)" /> <!--配置motor转速.default=10Hz, 取值范围5~15Hz-->
  
  </node>

</launch>
